# Copy these into Netlify → Site settings → Environment variables.
# The PRIVATE key is intentionally NOT stored here — set it only in Netlify.
# (Get the private key from where you saved it; regenerate anytime with `npm run vapid`.)

# Web Push (VAPID). Public key also lives in index.html (safe to expose).
VAPID_PUBLIC_KEY=BGWrzbVp3xos43JFLXlLgCAGEwdEToCBhHgI0ilyPmJYaGvVUlfZA55DVI-Y-mzyG1OjYYMVaBA_vEv20LJZWpw
VAPID_PRIVATE_KEY=set-this-in-netlify-only
VAPID_SUBJECT=mailto:admin@getdiscounted.my

# Shared secret protecting the /send function (invent your own long random string).
ADMIN_TOKEN=change-me-to-a-long-random-string

# Used by the GitHub Action to call the live /send endpoint after ingestion.
SITE_URL=https://getdiscounted.my
